# Optional: prefill OAuth config for development.
# The app UI also lets you paste the Client ID directly.
SLACK_CLIENT_ID=1234567890.1234567890123
SLACK_REDIRECT_URI=http://localhost:48731/slack/oauth/callback

# Optional fallback for development. Prefer OAuth in the app UI.
SLACK_USER_TOKEN=xoxp-your-user-token

# Optional: comma-separated Slack channel IDs to watch first.
# If omitted, the app uses visible DMs/private channels first, then falls back to recent visible channels.
SLACK_CHANNEL_IDS=C0123456789,C9876543210
